# ── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# ── Modalità di esecuzione: "polling" (sviluppo) | "webhook" (produzione) ────
BOT_MODE=polling

# ── Sicurezza — whitelist utenti ──────────────────────────────────────────────
# ID Telegram separati da virgola. Lascia vuoto per nessun filtro (sconsigliato).
ALLOWED_USER_IDS=123456789

# ── Webhook (obbligatori solo se BOT_MODE=webhook) ───────────────────────────
# URL pubblico HTTPS che Telegram chiamerà — deve puntare a questo server.
# In sviluppo usa ngrok: `ngrok http 8443` e copia l'URL https qui sotto.
WEBHOOK_URL=https://your-domain.com

# Porta locale su cui il server webhook ascolterà (Telegram accetta: 443, 80, 88, 8443)
WEBHOOK_PORT=8443

# Percorso dell'endpoint (il path dopo il dominio)
WEBHOOK_PATH=/webhook

# Token segreto per autenticare le richieste di Telegram (consigliato in produzione)
WEBHOOK_SECRET_TOKEN=change-this-to-a-random-secure-string

# ── AI Agent — Google Gemini ──────────────────────────────────────────────────
# Ottieni la chiave su https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-google-api-key-here
